# VidAiPro — copy to .env and fill in real values.
# NEVER commit .env to Git (it is in .gitignore).

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# --- Redis queue (Upstash) ---
REDIS_URL=rediss://default:PASSWORD@HOST:6379

# --- AI: Scripts + Images (NVIDIA Build) ---
# Kimi K2.6: https://build.nvidia.com/moonshotai/kimi-k2.6
# FLUX, Kimi, Magpie, etc. use this key (nvapi-...)
NVIDIA_API_KEY=

# --- AI: Images — Qwen fallback when FLUX CONTENT_FILTERED ---
# Model card: https://build.nvidia.com/qwen/qwen-image/modelcard
#
# Option A — Together AI partner (recommended, no GPU):
#   https://together.ai/models/qwen-image
QWEN_IMAGE_PROVIDER=together
TOGETHER_API_KEY=
# QWEN_IMAGE_MODEL=Qwen/Qwen-Image
# QWEN_IMAGE_MODEL=Qwen/Qwen-Image-2.0
#
# Option B — Self-hosted Qwen NIM on GPU:
# QWEN_IMAGE_PROVIDER=nim
# QWEN_IMAGE_BASE_URL=http://localhost:8000
# NVIDIA_API_KEY_QWEN=
#
QWEN_IMAGE_ENABLED=true
QWEN_IMAGE_ASPECT_RATIO=9:16
# QWEN_IMAGE_SIZE=768x1344

# --- AI: Scripts (optional — only if using Moonshot directly, not NVIDIA Build) ---
MOONSHOT_API_KEY=

# --- AI: Voice (TTS) ---
# Magpie multilingual (NVIDIA NVCF HTTP API — primary, same nvapi- key as FLUX/Kimi)
TTS_PROVIDER=magpie
TTS_VOICE=Magpie-Multilingual.EN-US.Aria
TTS_LANGUAGE=en-US
TTS_FALLBACK=magpie-grpc
TTS_SAMPLE_RATE_HZ=22050
MAGPIE_FUNCTION_ID=877104f7-e885-42b9-8de8-f6e4c6303969
MAGPIE_API_KEY=
# Or use NVIDIA_API_KEY above if one key for all NVIDIA Build models

# Chatterbox multilingual — see docs/TTS_MODELS.md
# Model: https://build.nvidia.com/resembleai/chatterbox-multilingual-tts/api
# Auth: OPENAI_API_KEY (NOT NVIDIA_API_KEY)
CHATTERBOX_FUNCTION_ID=ddacc747-1269-4fab-bfd9-8f593dead106
CHATTERBOX_VOICE=Chatterbox-Multilingual.en-US.Male
CHATTERBOX_GRPC_HOST=grpc.nvcf.nvidia.com:443

# Chatterbox bearer token — key from the Chatterbox model page above (stored as OPENAI_API_KEY)
OPENAI_API_KEY=

# --- File storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=vidaipro
R2_PUBLIC_URL=

# --- Local PC render server (Step 13+) ---
PC_SERVER_URL=https://ai.yourdomain.com
PC_API_SECRET=change-me-to-a-long-random-string
API_PUBLIC_URL=https://vidai-nw8e.onrender.com

# --- YouTube (Step 17) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.yourdomain.com/api/youtube/callback

# --- App ---
JWT_SECRET=change-me-to-another-long-random-string
PORT=3000
NODE_ENV=development

# --- Render (Path B) — set RUN_WORKER=true on free tier (API + queue in one process) ---
RUN_WORKER=true
YTDLP_PATH=./bin/yt-dlp
# After deploy, set GOOGLE_REDIRECT_URI to https://YOUR-APP.onrender.com/api/youtube/callback
