# VidAiPro — copy to .env and fill in real values.
# NEVER commit .env to Git (it is in .gitignore).

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# --- Redis queue (Upstash) ---
REDIS_URL=rediss://default:PASSWORD@HOST:6379

# --- AI: Images (NVIDIA Build — FLUX) ---
NVIDIA_API_KEY=

# --- AI: Scripts (Moonshot / Kimi K2.6) ---
MOONSHOT_API_KEY=

# --- AI: Voice (pick one) ---
OPENAI_API_KEY=
MAGPIE_API_KEY=
# Or use NVIDIA Magpie with NVIDIA_API_KEY above

# --- File storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=vidaipro
R2_PUBLIC_URL=

# --- Local PC render server (Step 13+) ---
PC_SERVER_URL=https://ai.yourdomain.com
PC_API_SECRET=change-me-to-a-long-random-string

# --- YouTube (Step 17) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.yourdomain.com/api/youtube/callback

# --- App ---
JWT_SECRET=change-me-to-another-long-random-string
PORT=3000
NODE_ENV=development

# --- Render (Path B) — set RUN_WORKER=true on free tier (API + queue in one process) ---
RUN_WORKER=true
# After deploy, set GOOGLE_REDIRECT_URI to https://YOUR-APP.onrender.com/api/youtube/callback
