# Copy to .env and fill in values. Do not commit .env.

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Redis
REDIS_URL=rediss://default:PASSWORD@HOST:6379

# NVIDIA Build (FLUX, Kimi, Magpie TTS fallback)
NVIDIA_API_KEY=

# Qwen image fallback (when FLUX is content-filtered)
QWEN_IMAGE_PROVIDER=together
TOGETHER_API_KEY=
QWEN_IMAGE_ENABLED=true
QWEN_IMAGE_ASPECT_RATIO=9:16

# Moonshot (optional, if not using NVIDIA Build for scripts)
MOONSHOT_API_KEY=

# Voice — Chatterbox primary, Magpie fallback (see docs/TTS_MODELS.md)
TTS_PROVIDER=chatterbox
TTS_VOICE=Magpie-Multilingual.EN-US.Mia
TTS_LANGUAGE=en-US
TTS_FALLBACK=magpie
TTS_SAMPLE_RATE_HZ=22050
MAGPIE_FUNCTION_ID=877104f7-e885-42b9-8de8-f6e4c6303969
MAGPIE_API_KEY=
CHATTERBOX_FUNCTION_ID=ddacc747-1269-4fab-bfd9-8f593dead106
CHATTERBOX_VOICE=Chatterbox-Multilingual.en-US.Male
CHATTERBOX_GRPC_HOST=grpc.nvcf.nvidia.com:443
OPENAI_API_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=vidaipro
R2_PUBLIC_URL=

# PC render server
PC_SERVER_URL=https://ai.yourdomain.com
PC_API_SECRET=change-me-to-a-long-random-string
API_PUBLIC_URL=https://vidai-nw8e.onrender.com

# YouTube OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.yourdomain.com/api/youtube/callback

# App
JWT_SECRET=change-me-to-another-long-random-string
PORT=3000
NODE_ENV=development
RUN_WORKER=true
YTDLP_PATH=./bin/yt-dlp
