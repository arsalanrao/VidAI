# VidAiPro ai-server — copy to .env and fill in.
# NEVER commit .env to Git.

# Must match PC_API_SECRET on Render backend
PC_API_SECRET=change-me-to-a-long-random-string

HOST=127.0.0.1
PORT=8000
OUTPUT_DIR=./outputs

# Hugging Face — required for gated SVD model (read token from huggingface.co/settings/tokens)
# 1. Accept license: https://huggingface.co/stabilityai/stable-video-diffusion-img2vid-xt-1-1
# 2. Create token with "Read" access
HF_TOKEN=

# Stable Video Diffusion (RTX 3070 8 GB defaults)
SVD_MODEL=stabilityai/stable-video-diffusion-img2vid-xt-1-1
SVD_NUM_FRAMES=14
SVD_FPS=7
SVD_WIDTH=576
SVD_HEIGHT=1024
SVD_DECODE_CHUNK_SIZE=2
